# Lead form endpoint (demo request + waitlist submit here).
# Create a form on Formspree (https://formspree.io) or Getform and paste its
# submission URL below. This is a public submission URL, not a secret.
# Without it, the demo form falls back to opening a prefilled email.
NEXT_PUBLIC_LEAD_ENDPOINT=

# ── Dashboard (Supabase) ─────────────────────────────────────────────────────
# Public, browser-safe values only. The dashboard talks to Supabase PostgREST
# directly as role `authenticated`; RLS is the tenant fence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEVER put SUPABASE_SERVICE_ROLE_KEY (or any service-role / sb_secret_ key)
# in this app or its env — it bypasses RLS. The CI guard fails the build if a
# service-role pattern appears in the source. Service-role lives only in the
# backend (Railway).
